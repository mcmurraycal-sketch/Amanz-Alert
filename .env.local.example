# Copy this file to .env.local and fill in real values from your Supabase project dashboard.
# Settings -> API in the Supabase dashboard.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Map tiles (free OpenStreetMap-based provider).
# Sign up at https://www.maptiler.com/ -> Free tier is more than enough for MVP.
NEXT_PUBLIC_MAPTILER_KEY=YOUR-MAPTILER-KEY
